.container {
  padding: 20rpx 30rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.section { margin-bottom: 30rpx; }

/* Upload */
.upload-area {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 400rpx; background: #fff; border-radius: 20rpx; border: 3rpx dashed #d9d9d9;
}
.upload-area:active { border-color: #4facfe; background: #f0faff; }
.upload-icon { font-size: 80rpx; color: #bbb; line-height: 1; margin-bottom: 16rpx; }
.upload-text { font-size: 28rpx; color: #999; }

/* Canvas */
.canvas-wrapper {
  position: relative; background: #e8e8e8; border-radius: 16rpx; overflow: hidden; margin: 0 auto;
}
.re-select { text-align: center; padding: 20rpx 0; }
.re-select text { font-size: 26rpx; color: #4facfe; }

/* Config */
.config-panel { background: #fff; border-radius: 16rpx; padding: 30rpx; }
.config-title { font-size: 30rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 24rpx; }
.config-item { margin-bottom: 28rpx; }
.config-item:last-child { margin-bottom: 0; }
.config-label { display: block; font-size: 26rpx; color: #666; margin-bottom: 12rpx; }

/* Icon select */
.icon-select {
  width: 120rpx; height: 120rpx; background: #f5f5f5; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center; border: 2rpx dashed #d9d9d9;
}
.icon-preview { width: 100%; height: 100%; border-radius: 12rpx; }
.icon-select-text { font-size: 24rpx; color: #999; }

/* Picker */
.picker-value { background: #f5f5f5; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; color: #333; }

/* Actions */
.action-bar { padding-top: 10rpx; }
.btn-primary {
  width: 100%; height: 96rpx; line-height: 96rpx;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff; font-size: 32rpx; font-weight: 600; border-radius: 16rpx; border: none;
}
.btn-primary:active { opacity: 0.85; }
.btn-primary[disabled] { background: #ccc; color: #fff; }

/* Result */
.result-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.result-panel {
  width: 85%; max-height: 85vh; background: #fff; border-radius: 24rpx;
  padding: 36rpx; display: flex; flex-direction: column;
}
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.result-title { font-size: 34rpx; font-weight: 600; color: #1a1a1a; }
.result-close {
  width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 50%; background: #f5f5f5;
}
.result-close text { font-size: 28rpx; color: #999; }
.result-image-wrap {
  flex: 1; display: flex; align-items: center; justify-content: center;
  min-height: 300rpx; max-height: 60vh;
}
.result-image { width: 100%; max-height: 60vh; border-radius: 12rpx; }
.result-tip { text-align: center; padding: 16rpx 0; }
.result-tip text { font-size: 22rpx; color: #bbb; }
.result-actions { display: flex; gap: 20rpx; margin-top: 10rpx; }
.btn-save {
  flex: 1; height: 84rpx; line-height: 84rpx;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff; font-size: 28rpx; font-weight: 600; border-radius: 14rpx; border: none;
}
.btn-save:active { opacity: 0.85; }
.btn-redo {
  flex: 1; height: 84rpx; line-height: 84rpx;
  background: #f5f5f5; color: #666; font-size: 28rpx; border-radius: 14rpx; border: none;
}
.btn-redo:active { background: #eee; }
