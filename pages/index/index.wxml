<view class="page">
  <!-- 头部说明区域 -->
  <view class="header">
    <text class="header-title">图片工具箱</text>
    <text class="header-desc">选择你需要的图片处理工具</text>
  </view>

  <!-- 工具卡片网格 -->
  <view class="tool-grid">
    <view
      class="tool-card"
      wx:for="{{modules}}"
      wx:key="id"
      data-path="{{item.path}}"
      bindtap="onModuleTap"
    >
      <view class="tool-icon" style="background: {{item.gradient}};">
        <text class="tool-icon-text">{{item.emoji}}</text>
      </view>
      <text class="tool-name">{{item.name}}</text>
      <text class="tool-desc">{{item.desc}}</text>
    </view>
  </view>
</view>
