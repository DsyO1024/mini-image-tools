<view class="container">
  <view class="header">
    <text class="title">图片工具箱</text>
    <text class="subtitle">选择你需要的图片处理工具</text>
  </view>

  <view class="module-list">
    <view
      class="module-card"
      wx:for="{{modules}}"
      wx:key="id"
      data-path="{{item.path}}"
      bindtap="onModuleTap"
    >
      <view class="module-icon icon-{{item.icon}}">
        <view class="icon-inner">
          <!-- Watermark icon using CSS -->
          <view wx:if="{{item.icon === 'watermark'}}" class="icon-watermark">
            <view class="icon-img-placeholder"></view>
            <view class="icon-drop"></view>
          </view>
        </view>
      </view>
      <view class="module-info">
        <text class="module-name">{{item.name}}</text>
        <text class="module-desc">{{item.desc}}</text>
      </view>
      <view class="module-arrow">
        <text class="arrow-text">></text>
      </view>
    </view>
  </view>
</view>
