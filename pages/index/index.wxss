/* ========== 页面整体 ========== */
.page {
  min-height: 100vh;
  background: #e8e8e8;
  padding: 0 24rpx 60rpx;
}

/* ========== 头部说明 ========== */
.header {
  height: 100rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 8rpx;
}

.header-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.2;
}

.header-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ========== 工具卡片网格 ========== */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tool-card {
  width: calc(50% - 10rpx);
  background: #d9d9d9;
  border-radius: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.tool-card:active {
  opacity: 0.8;
  transform: scale(0.97);
}

/* ========== 工具图标 ========== */
.tool-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.tool-icon-text {
  font-size: 40rpx;
  line-height: 1;
  color: #fff;
}

/* ========== 工具名称与描述 ========== */
.tool-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 10rpx;
  line-height: 1.3;
}

.tool-desc {
  display: block;
  font-size: 22rpx;
  color: #777;
  line-height: 1.5;
}
