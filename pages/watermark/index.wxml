<view class="container">
  <!-- Select Image Area -->
  <view class="section" wx:if="{{!imageSrc}}">
    <view class="upload-area" bindtap="chooseImage">
      <view class="upload-icon">+</view>
      <text class="upload-text">从相册选择图片</text>
    </view>
  </view>

  <!-- Image Preview & Canvas -->
  <view class="section" wx:if="{{imageSrc}}">
    <view class="canvas-wrapper" style="width:{{canvasWidth}}px;height:{{canvasHeight}}px;">
      <canvas
        id="watermarkCanvas"
        type="2d"
        style="width:{{canvasWidth}}px;height:{{canvasHeight}}px;"
        bindtouchstart="onCanvasTouchStart"
        bindtouchmove="onCanvasTouchMove"
        bindtouchend="onCanvasTouchEnd"
      ></canvas>
      <view class="mosaic-hint" wx:if="{{mode === 'mosaic'}}">
        <text>用手指涂抹需要打码的区域</text>
      </view>
    </view>

    <!-- Re-select -->
    <view class="re-select" bindtap="reSelectImage">
      <text>重新选择图片</text>
    </view>
  </view>

  <!-- Mode Tabs -->
  <view class="section" wx:if="{{imageSrc}}">
    <view class="mode-tabs">
      <view
        class="mode-tab {{mode === 'text' ? 'active' : ''}}"
        data-mode="text"
        bindtap="onModeChange"
      >
        <text>文字水印</text>
      </view>
      <view
        class="mode-tab {{mode === 'mosaic' ? 'active' : ''}}"
        data-mode="mosaic"
        bindtap="onModeChange"
      >
        <text>马赛克</text>
      </view>
      <view
        class="mode-tab {{mode === 'icon' ? 'active' : ''}}"
        data-mode="icon"
        bindtap="onModeChange"
      >
        <text>图标水印</text>
      </view>
    </view>
  </view>

  <!-- Text Watermark Config -->
  <view class="section config-panel" wx:if="{{imageSrc && mode === 'text'}}">
    <view class="config-title">文字水印设置</view>

    <view class="config-item">
      <text class="config-label">水印文字</text>
      <input
        class="config-input"
        value="{{textContent}}"
        bindinput="onTextInput"
        placeholder="输入水印文字"
      />
    </view>

    <view class="config-item">
      <text class="config-label">字体大小: {{textSize}}</text>
      <slider
        min="12"
        max="80"
        value="{{textSize}}"
        activeColor="#667eea"
        bindchange="onTextSizeChange"
      />
    </view>

    <view class="config-item">
      <text class="config-label">文字颜色</text>
      <view class="color-list">
        <view
          wx:for="{{colorOptions}}"
          wx:key="*this"
          class="color-item {{textColor === item ? 'selected' : ''}}"
          style="background:{{item}}"
          data-color="{{item}}"
          bindtap="onTextColorTap"
        ></view>
      </view>
    </view>

    <view class="config-item">
      <text class="config-label">透明度: {{textOpacity}}%</text>
      <slider
        min="10"
        max="100"
        value="{{textOpacity}}"
        activeColor="#667eea"
        bindchange="onTextOpacityChange"
      />
    </view>

    <view class="config-item">
      <text class="config-label">位置</text>
      <picker range="{{positionOptions}}" range-key="label" bindchange="onTextPositionChange">
        <view class="picker-value">
          <block wx:for="{{positionOptions}}" wx:key="value">
            <text wx:if="{{item.value === textPosition}}">{{item.label}}</text>
          </block>
        </view>
      </picker>
    </view>
  </view>

  <!-- Mosaic Config -->
  <view class="section config-panel" wx:if="{{imageSrc && mode === 'mosaic'}}">
    <view class="config-title">马赛克设置</view>

    <view class="config-item">
      <text class="config-label">马赛克大小: {{mosaicSize}}</text>
      <slider
        min="5"
        max="40"
        value="{{mosaicSize}}"
        activeColor="#667eea"
        bindchange="onMosaicSizeChange"
      />
    </view>

    <view class="config-item">
      <view class="clear-btn" bindtap="clearMosaic">
        <text>清除涂抹</text>
      </view>
    </view>
  </view>

  <!-- Icon Watermark Config -->
  <view class="section config-panel" wx:if="{{imageSrc && mode === 'icon'}}">
    <view class="config-title">图标水印设置</view>

    <view class="config-item">
      <text class="config-label">水印图标</text>
      <view class="icon-select" bindtap="chooseIcon">
        <image wx:if="{{iconSrc}}" src="{{iconSrc}}" class="icon-preview" mode="aspectFit" />
        <text wx:else class="icon-select-text">+ 选择图标</text>
      </view>
    </view>

    <view class="config-item">
      <text class="config-label">图标大小: {{iconSize}}</text>
      <slider
        min="20"
        max="200"
        value="{{iconSize}}"
        activeColor="#667eea"
        bindchange="onIconSizeChange"
      />
    </view>

    <view class="config-item">
      <text class="config-label">透明度: {{iconOpacity}}%</text>
      <slider
        min="10"
        max="100"
        value="{{iconOpacity}}"
        activeColor="#667eea"
        bindchange="onIconOpacityChange"
      />
    </view>

    <view class="config-item">
      <text class="config-label">位置</text>
      <picker range="{{positionOptions}}" range-key="label" bindchange="onIconPositionChange">
        <view class="picker-value">
          <block wx:for="{{positionOptions}}" wx:key="value">
            <text wx:if="{{item.value === iconPosition}}">{{item.label}}</text>
          </block>
        </view>
      </picker>
    </view>
  </view>

  <!-- Action Buttons -->
  <view class="section action-bar" wx:if="{{imageSrc}}">
    <button class="btn-primary" bindtap="applyWatermark" disabled="{{processing}}">
      {{processing ? '处理中...' : '生成水印图片'}}
    </button>
  </view>

  <!-- Result Modal -->
  <view class="result-mask" wx:if="{{showResult}}" bindtap="closeResult">
    <view class="result-panel" catchtap="">
      <view class="result-header">
        <text class="result-title">处理完成</text>
        <view class="result-close" bindtap="closeResult">
          <text>X</text>
        </view>
      </view>
      <view class="result-image-wrap">
        <image
          src="{{resultImageSrc}}"
          class="result-image"
          mode="aspectFit"
          bindtap="previewResult"
        />
      </view>
      <view class="result-tip">
        <text>点击图片可预览大图</text>
      </view>
      <view class="result-actions">
        <button class="btn-save" bindtap="saveToAlbum">保存到相册</button>
        <button class="btn-redo" bindtap="reSelectImage">处理其他图片</button>
      </view>
    </view>
  </view>
</view>
