.container {
  padding: 20rpx 30rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.section {
  margin-bottom: 30rpx;
}

/* Upload Area */
.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 3rpx dashed #d9d9d9;
}

.upload-area:active {
  border-color: #667eea;
  background: #f8f8ff;
}

.upload-icon {
  font-size: 80rpx;
  color: #bbb;
  line-height: 1;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #999;
}

/* Canvas */
.canvas-wrapper {
  position: relative;
  background: #e8e8e8;
  border-radius: 16rpx;
  overflow: hidden;
  margin: 0 auto;
}

.mosaic-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.5);
  padding: 12rpx 0;
  text-align: center;
}

.mosaic-hint text {
  color: #fff;
  font-size: 24rpx;
}

.re-select {
  text-align: center;
  padding: 20rpx 0;
}

.re-select text {
  font-size: 26rpx;
  color: #667eea;
}

/* Mode Tabs */
.mode-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  gap: 8rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.mode-tab.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-weight: 600;
}

.mode-tab:active {
  opacity: 0.8;
}

/* Config Panel */
.config-panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.config-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.config-item {
  margin-bottom: 28rpx;
}

.config-item:last-child {
  margin-bottom: 0;
}

.config-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.config-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

/* Color picker */
.color-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.color-item {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.color-item.selected {
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.3);
}

.color-item[style*="background:#ffffff"],
.color-item[style*="background: #ffffff"] {
  border: 2rpx solid #e0e0e0;
}

/* Picker */
.picker-value {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* Icon select */
.icon-select {
  width: 120rpx;
  height: 120rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d9d9d9;
}

.icon-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.icon-select-text {
  font-size: 24rpx;
  color: #999;
}

/* Clear button */
.clear-btn {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 30rpx;
  background: #fff0f0;
  color: #ff4d4f;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.clear-btn:active {
  opacity: 0.7;
}

/* Action Bar */
.action-bar {
  padding-top: 10rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary[disabled] {
  background: #ccc;
  color: #fff;
}

/* Result Modal */
.result-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-panel {
  width: 85%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.result-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.result-close text {
  font-size: 28rpx;
  color: #999;
}

.result-image-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  max-height: 60vh;
}

.result-image {
  width: 100%;
  max-height: 60vh;
  border-radius: 12rpx;
}

.result-tip {
  text-align: center;
  padding: 16rpx 0;
}

.result-tip text {
  font-size: 22rpx;
  color: #bbb;
}

.result-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 10rpx;
}

.btn-save {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 14rpx;
  border: none;
}

.btn-save:active {
  opacity: 0.85;
}

.btn-redo {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 14rpx;
  border: none;
}

.btn-redo:active {
  background: #eee;
}
